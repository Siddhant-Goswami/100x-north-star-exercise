# Copy to .env.local and fill in. .env.local is gitignored.

# Canonical app URL for auth redirect links (email confirmation). Set in
# production (e.g. https://your-app.vercel.app). Unset locally → browser origin.
NEXT_PUBLIC_SITE_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
# service_role key (Dashboard → Project Settings → API). Server-only secret.
SUPABASE_SERVICE_ROLE_KEY=

# LLM provider keys (server-only). Fill the ones your roadmaps use.
# Groq is the default provider for now — set this one at minimum.
GROQ_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# Salt for hashing participant IPs (per-IP rate limiting).
IP_HASH_SALT=change-me
